# =============================================================================
# COPE — Environment Variables
# Copy this file to .env and fill in all values before running the project.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL 17)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# -----------------------------------------------------------------------------
# Auth (JWT — local bcrypt against PostgreSQL; Supabase retired)
# Refresh tokens are first-party, opaque, hashed, and rotated on use.
# -----------------------------------------------------------------------------
JWT_SECRET="minimum-32-character-secret-for-jwt-signing"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# -----------------------------------------------------------------------------
# API Server
# -----------------------------------------------------------------------------
API_PORT=3000
API_HOST="0.0.0.0"
NODE_ENV="development"
CORS_ORIGIN="http://localhost:5173"
# Origin of the clinician web app (used in notification/report links)
WEB_APP_URL="http://localhost:5173"

# -----------------------------------------------------------------------------
# Redis (for BullMQ rules engine + WebSocket pub/sub)
# -----------------------------------------------------------------------------
REDIS_URL="redis://localhost:6379"

# -----------------------------------------------------------------------------
# File Storage (local filesystem — replaces Supabase Storage)
# Objects live under STORAGE_DIR/<bucket>/<path>; downloads are HMAC-signed
# URLs served by GET /api/v1/files/<bucket>/<path>?exp=...&sig=...
# -----------------------------------------------------------------------------
STORAGE_DIR="./storage"
# Absolute prefix for signed download URLs. Leave empty when the web app and
# API share an origin (links are then relative); set to the API's public
# origin when they differ, e.g. "https://cope.acumenus.net".
API_PUBLIC_URL=""

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY="re_your_resend_api_key"
EMAIL_FROM="COPE Alerts <alerts@yourdomain.com>"

# -----------------------------------------------------------------------------
# SMS (Twilio — critical alerts only)
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_FROM_NUMBER="+15550000000"

# -----------------------------------------------------------------------------
# AI Insights
# Set AI_PROVIDER to "ollama" for local inference (no BAA required) or
# "anthropic" for cloud inference (requires signed BAA).
# -----------------------------------------------------------------------------
AI_PROVIDER="anthropic"
ANTHROPIC_API_KEY="sk-ant-your-anthropic-key"
ANTHROPIC_MODEL="claude-sonnet-4-5-20250929"
AI_INSIGHTS_ENABLED="false"

# Ollama (local LLM — used when AI_PROVIDER=ollama)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="alibayram/medgemma:27b"

# -----------------------------------------------------------------------------
# Push Notifications (Expo Push Service → APNs + FCM)
# -----------------------------------------------------------------------------
EXPO_ACCESS_TOKEN="your-expo-access-token"

# -----------------------------------------------------------------------------
# Crisis Resource Contacts (United States)
# Verified quarterly — see SAF-002
# -----------------------------------------------------------------------------
CRISIS_LINE_PHONE="988"
CRISIS_LINE_NAME="988 Suicide & Crisis Lifeline"
CRISIS_TEXT_NUMBER="741741"
CRISIS_TEXT_NAME="Crisis Text Line"

# -----------------------------------------------------------------------------
# Compliance
# -----------------------------------------------------------------------------
# Set to "true" only after BAA with Anthropic is signed
ANTHROPIC_BAA_SIGNED="false"
# Set to "true" only after HIPAA security risk assessment is complete
HIPAA_ASSESSMENT_COMPLETE="false"
