node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
.next/
out/
.expo/

# Environment
.env
.env.local
.env.*.local

# Turbo
.turbo/

# Testing
coverage/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# Editor
.vscode/
.idea/
*.swp
*.swo

# TypeScript
*.tsbuildinfo

# Compiled JS that lands in src/ by mistake (outDir should be dist/)
packages/*/src/**/*.js
packages/*/src/**/*.js.map

# Expo/EAS root-level stub (created when eas/expo commands run from wrong dir)
/app.json

# Mobile
/android/
/ios/
apps/android/.gradle/
apps/android/build/
apps/android/app/build/
apps/android/local.properties
apps/ios/*.xcodeproj/
apps/ios/build/
*.keystore
*.jks
*.p8
*.p12
*.mobileprovision

# Secrets (never commit these)
*.pem
*.key
secrets/

# Production/demo env files contain real secrets — never track (untracked 2026-06-12 after JWT_SECRET leak)
.env.production
.env.demo
.env.production.bak*
storage/

# Swift Package Manager build artifacts (local SPM packages under apps/ios/Packages)
.build/
.swiftpm/

# mobile-contracts generated Android build caches
packages/mobile-contracts/generated/android/.gradle/
packages/mobile-contracts/generated/android/bin/

# Stray local inspection scripts (may contain DB creds) — never commit
_inspect.mjs
_*.mjs
